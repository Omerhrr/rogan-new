# ─── Rogan Live v3 — Environment Variables ───────────────────
# Copy this file to .env and fill in your values

# JWT (MUST change in production!)
JWT_SECRET=rogan-live-production-secret-change-me

# Google OAuth (optional — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database (defaults work for Docker Compose)
DATABASE_URL=postgresql://rogan:rogan_secret@postgres:5432/rogan_live

# Redis
REDIS_URL=redis://redis:6379/0

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# MediaMTX
MEDIAMTX_HOST=mediamtx
